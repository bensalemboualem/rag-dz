# ==============================================
# RAG.dz Environment Configuration
# ==============================================
# Copy this file to .env and update values

# ==============================================
# Database Configuration
# ==============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=archon

# ==============================================
# Redis Configuration
# ==============================================
REDIS_PASSWORD=

# ==============================================
# Security & API
# ==============================================
# Generate with: openssl rand -hex 32
API_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8180

# ==============================================
# Rate Limiting
# ==============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10
ENABLE_RATE_LIMITING=true

# ==============================================
# Cloud LLM Configuration
# ==============================================
# Choose provider: openai, anthropic
LLM_PROVIDER=openai

# OpenAI (gpt-3.5-turbo, gpt-4, gpt-4-turbo, etc)
OPENAI_API_KEY=sk-your-openai-api-key-here
# Anthropic Claude (claude-3-haiku, claude-3-sonnet, claude-3-opus)
ANTHROPIC_API_KEY=

# Model name based on provider
LLM_MODEL=gpt-3.5-turbo

# ==============================================
# Embeddings Configuration
# ==============================================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ==============================================
# Service Configuration
# ==============================================
LOG_LEVEL=INFO
ENVIRONMENT=development

# ==============================================
# Feature Flags
# ==============================================
ENABLE_CORS=true
ENABLE_METRICS=true
ENABLE_API_KEY_AUTH=true

# ==============================================
# Frontend Configuration
# ==============================================
VITE_API_URL=http://localhost:8180
VITE_WS_URL=ws://localhost:8180/ws
VITE_API_KEY=
VITE_ENABLE_DEV_TOOLS=true

# ==============================================
# Monitoring
# ==============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ==============================================
# NOUVELLES FONCTIONNALITÉS D'ARCHON
# ==============================================

# Reranking - Améliore la pertinence des résultats de recherche
USE_RERANKING=true
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKING_TOP_K=10

# PGVector - Recherche vectorielle dans PostgreSQL (alternative à Qdrant)
USE_PGVECTOR=true

# Meilisearch (déjà configuré mais ajouté ici pour référence)
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=ragdzMasterKey2024
