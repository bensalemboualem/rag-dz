###############################################################################
# IAFactory RAG-DZ - Configuration Production
# Domaine: www.iafactoryalgeria.com
# Date: 2025-11-24
###############################################################################

# =============================================================================
# DOMAINE ET URLS
# =============================================================================
DOMAIN=www.iafactoryalgeria.com
EMAIL=admin@iafactoryalgeria.com
FRONTEND_URL=https://www.iafactoryalgeria.com
BACKEND_URL=https://www.iafactoryalgeria.com/api

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=iafactory_admin
POSTGRES_PASSWORD=CHANGEME_LONG_SECURE_PASSWORD_HERE
POSTGRES_DB=iafactory_prod

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD_HERE

# =============================================================================
# SECURITY
# =============================================================================
# Générer avec: openssl rand -hex 32
RAG_API_KEY=CHANGEME_RAG_API_KEY_HERE
JWT_SECRET_KEY=CHANGEME_JWT_SECRET_KEY_HERE
API_SECRET_KEY=CHANGEME_API_SECRET_KEY_HERE

# =============================================================================
# AI PROVIDERS
# =============================================================================

# OpenAI (GPT-4, GPT-3.5)
# Obtenir sur: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude (Claude 3.5 Sonnet, Claude 3 Opus)
# Obtenir sur: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq (Llama 3, Mixtral - ULTRA RAPIDE & GRATUIT)
# Obtenir sur: https://console.groq.com/keys
GROQ_API_KEY=

# Abacus AI (Smaug, Dracarys)
# Obtenir sur: https://console.abacus.ai/
ABACUS_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Configuration par défaut
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# === URLS FRONTEND ===
VITE_API_URL=https://api.iafactory.dz
VITE_WS_URL=wss://api.iafactory.dz/ws

# === CORS (domaines autorisés) ===
ALLOWED_ORIGINS=https://iafactory.dz,https://app.iafactory.ch,https://studio.iafactory.dz

# === RATE LIMITING ===
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=3000

# === EMBEDDINGS ===
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# === RERANKING ===
USE_RERANKING=true
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKING_TOP_K=10

# === LOGS ===
LOG_LEVEL=INFO

# === FIREBASE (Key Service) ===
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
